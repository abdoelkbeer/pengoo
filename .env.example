SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

NEXT_PUBLIC_APP_URL=https://your-domain.com

# Local VPS SMTP relay example:
# SMTP_HOST=127.0.0.1
# SMTP_PORT=25
# SMTP_SENDER_EMAIL=noreply@your-domain.com
# SMTP_SENDER_NAME=Pengoo
#
# Authenticated SMTP example:
# SMTP_HOST=smtp.your-domain.com
# SMTP_PORT=587
# SMTP_USER=noreply@your-domain.com
# SMTP_PASSWORD=your-smtp-password
# SMTP_SENDER_EMAIL=noreply@your-domain.com
# SMTP_SENDER_NAME=Pengoo
# SMTP_REQUIRE_TLS=true

WHATSAPP_WORKER_URL=https://your-worker-domain.com
WORKER_API_KEY=generate-a-long-random-worker-key

CRON_SECRET=generate-a-long-random-cron-secret

NEXT_PUBLIC_RECAPTCHA_SITE_KEY=your-recaptcha-site-key
RECAPTCHA_SECRET_KEY=your-recaptcha-secret-key
RECAPTCHA_MIN_SCORE=0.5

NEXT_PUBLIC_META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_CONFIG_ID=your-meta-config-id
